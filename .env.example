# Copy to .env and fill in real values. .env is gitignored.

# Required — API keys
GOOGLE_API_KEY=              # https://ai.google.dev (free tier) — used for Gemini 2.5 Flash captioning
GROQ_API_KEY=                # https://console.groq.com (free tier) — used for Llama 3.3 70B answers

# Paths (defaults are fine for a fresh clone)
PDF_PATH=data/source.pdf
CHROMA_PATH=data/chroma_db
CACHE_DIR=data/cache
IMAGES_DIR=data/images
CHUNKS_PATH=data/chunks.jsonl

# Logging
LOG_LEVEL=INFO

# Feature flags
USE_ROUTER=false             # Phase 6: flip to true to A/B the query router

# Tuning
EVAL_INTER_QUESTION_DELAY_S=2.0   # seconds between questions in eval to stay under Groq free-tier rate limits
